Cobre artefatos comuns de SO, editor, segredos/.env e caches de
Python/Node, antecipando ferramentas de automação futuras.
---
 .gitignore | 26 ++++++++++++++++++++++++++
 1 file changed, 26 insertions(+)
 create mode 100644 .gitignore

diff --git a/.gitignore b/.gitignore
new file mode 100644
index 0000000..7dc8a9c
--- /dev/null
+++ b/.gitignore
@@ -0,0 +1,26 @@
+# OS
+.DS_Store
+Thumbs.db
+
+# Editor
+.vscode/
+.idea/
+*.swp
+
+# Environment / secrets
+.env
+.env.*
+*.key
+*.pem
+
+# Logs
+*.log
+
+# Python (caso scripts de automação sejam adicionados futuramente)
+__pycache__/
+*.pyc
+.venv/
+venv/
+
+# Node (caso tooling JS seja adicionado)
+node_modules/
