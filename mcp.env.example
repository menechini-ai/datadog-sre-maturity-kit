# Datadog MCP Server - Environment Variables
# Copie este arquivo para .env e preencha os valores

# Datadog Site (mesmo usado no mcp.json)
DD_SITE=datadoghq.com

# API Key do Datadog (gerar em: https://datadoghq.com/organization-settings/api-keys)
DD_API_KEY=seu-api-key-aqui

# Application Key do Datadog (gerar em: https://datadoghq.com/organization-settings/application-keys)
DD_APP_KEY=seu-app-key-aqui
